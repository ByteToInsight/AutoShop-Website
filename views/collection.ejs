<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= category %> | DriveStylish</title>
  <style>
    :root {
      --text-color: #677279;
      --heading-color: #000000;
      --accent-color: #ff0000;
      --button-bg: #ed1e24;
      --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    body {
      margin: 0;
      font-family: var(--font-family);
      color: var(--text-color);
      background: #fff;
    }
    .header {
      background: #000;
      color: #fff;
      padding: 10px;
      text-align: center;
      font-size: 14px;
    }
    .nav {
      padding: 20px 40px;
      border-bottom: 1px solid #eee;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav a { color: #000; text-decoration: none; font-weight: bold; font-size: 24px; }
    .page-title {
      text-align: center;
      padding: 40px 20px 20px;
      font-size: 28px;
      color: var(--heading-color);
      text-transform: capitalize;
    }
    .products-grid {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 24px;
    }
    .product-card {
      border: 1px solid #f2f2f2;
      border-radius: 8px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      display: block;
      transition: box-shadow 0.2s;
    }
    .product-card:hover {
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
    .product-card img {
      width: 100%;
      display: block;
    }
    .product-card .info {
      padding: 16px;
    }
    .product-card .title {
      font-size: 16px;
      color: var(--heading-color);
      margin: 0 0 8px;
    }
    .product-card .price {
      font-size: 18px;
      font-weight: bold;
      color: var(--heading-color);
    }
    .product-card .original-price {
      text-decoration: line-through;
      color: var(--text-color);
      font-size: 14px;
      margin-left: 8px;
    }
  </style>
</head>
<body>
  <div class="header">
    Flat 3% Off on All Prepaid Orders | Min Order ₹3999 = Free Gift | Free Shipping
  </div>
  <div class="nav">
    <a href="/">Drive<span style="color:#ed1e24">Stylish</span></a>
    <div>
      <a href="/" style="font-size: 16px; font-weight: normal; margin-right: 20px;">Home</a>
      <a href="/collections/all" style="font-size: 16px; font-weight: normal;">Shop All</a>
    </div>
  </div>

  <h1 class="page-title"><%= category %></h1>

  <div class="products-grid">
    <% products.forEach(function(product) { %>
      <a href="/products/<%= product.handle %>" class="product-card">
        <img src="<%= product.image_url %>" alt="<%= product.title %>">
        <div class="info">
          <h3 class="title"><%= product.title %></h3>
          <div class="price">
            <%= product.price %>
            <% if(product.original_price) { %>
              <span class="original-price"><%= product.original_price %></span>
            <% } %>
          </div>
        </div>
      </a>
    <% }); %>
  </div>
</body>
</html>
