<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= product.title %> | DriveStylish</title>
  <style>
    /* Mimic exact site fonts and styling */
    :root {
      --text-color: #677279;
      --heading-color: #000000;
      --accent-color: #ff0000;
      --button-bg: #ed1e24;
      --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    body {
      margin: 0;
      font-family: var(--font-family);
      color: var(--text-color);
      background: #fff;
    }
    .header {
      background: #000;
      color: #fff;
      padding: 10px;
      text-align: center;
      font-size: 14px;
    }
    .nav {
      padding: 20px 40px;
      border-bottom: 1px solid #eee;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav a { color: #000; text-decoration: none; font-weight: bold; font-size: 24px;}
    .product-container {
      max-width: 1200px;
      margin: 40px auto;
      padding: 0 20px;
      display: flex;
      gap: 40px;
    }
    .product-image {
      flex: 1;
      border: 1px solid #f2f2f2;
      border-radius: 8px;
      overflow: hidden;
    }
    .product-image img {
      width: 100%;
      display: block;
    }
    .product-info {
      flex: 1;
    }
    .product-title {
      font-size: 32px;
      color: var(--heading-color);
      margin-top: 0;
    }
    .product-price {
      font-size: 24px;
      color: var(--heading-color);
      font-weight: bold;
      margin: 20px 0;
    }
    .original-price {
      text-decoration: line-through;
      color: var(--text-color);
      font-size: 18px;
      margin-left: 10px;
    }
    .btn {
      display: block;
      width: 100%;
      padding: 15px;
      background: var(--button-bg);
      color: #fff;
      text-align: center;
      text-decoration: none;
      font-weight: bold;
      text-transform: uppercase;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 16px;
      margin-top: 30px;
    }
    .btn:hover {
      opacity: 0.9;
    }
    .description {
      margin-top: 40px;
      line-height: 1.6;
    }
  </style>
</head>
<body>

  <div class="header">
    Flat 3% Off on All Prepaid Orders | Min Order ₹3999 = Free Gift | Free Shipping
  </div>
  <div class="nav">
    <a href="/">Drive<span style="color:#ed1e24">Stylish</span></a>
    <div>
      <a href="/" style="font-size: 16px; font-weight: normal; margin-right: 20px;">Home</a>
      <a href="/collections/all" style="font-size: 16px; font-weight: normal;">Shop All</a>
    </div>
  </div>

  <div class="product-container">
    <div class="product-image">
      <img src="<%= product.image_url %>" alt="<%= product.title %>">
    </div>
    <div class="product-info">
      <h1 class="product-title"><%= product.title %></h1>
      <div class="product-price">
        <%= product.price %>
        <% if(product.original_price) { %>
          <span class="original-price"><%= product.original_price %></span>
        <% } %>
      </div>
      
      <button class="btn">Add to Cart</button>
      <button class="btn" style="background: #000; margin-top: 10px;">Buy it Now</button>

      <div class="description">
        <h3>Description</h3>
        <p><%= product.description %></p>
        <p><em>(Data dynamically loaded from local SQLite database)</em></p>
      </div>
    </div>
  </div>

</body>
</html>
